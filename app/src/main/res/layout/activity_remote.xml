<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline132"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.89" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline209"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.475" />

    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/light_gray"
        app:layout_constraintBottom_toTopOf="@+id/guideline132"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/txt1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/GROUNDbg_stonex_blue"
        android:gravity="center"
        android:padding="3dp"
        android:text="REMOTE PROJECTS FOLDER"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider48" />


    <TextView
        android:id="@+id/txt2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/custom_background_test3d_box"
        android:gravity="center"
        android:padding="3dp"
        android:text="LOCAL PROJECTS FOLDER"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toStartOf="@+id/divider48"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/divider48"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:background="@color/_____cancel_text"
        android:orientation="horizontal"
        android:gravity="center"

        app:layout_constraintBottom_toTopOf="@+id/guideline209"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline209">

        <ImageView
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="5dp"
            android:layout_marginVertical="15dp"
            android:layout_weight="0"
            android:background="@color/nav_gray_color"
            app:srcCompat="@drawable/delete_raw" />


        <ImageView
            android:rotation="90"
            android:id="@+id/upload"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="5dp"

            android:layout_weight="0"
            android:background="@color/nav_gray_color"
            app:srcCompat="@drawable/copia_destra"
            app:tint="@color/black" />

        <ImageView
            android:rotation="90"
            android:id="@+id/download"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="5dp"

            android:layout_weight="0"
            android:background="@color/nav_gray_color"
            app:srcCompat="@drawable/copia_sinistra" />

        <ImageView
            android:rotation="90"
            android:id="@+id/refresh"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="0"
            android:background="@color/nav_gray_color"
            app:srcCompat="@drawable/btn_refresh" />


    </LinearLayout>

    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@color/nav_gray_color"
        app:layout_constraintTop_toTopOf="@+id/guideline132">

        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:rotation="180"
            app:tint="@color/white"
            app:srcCompat="@drawable/menu_btn" />

        <ImageView
            android:id="@+id/update"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/btn_refresh"
            app:tint="@color/_____cancel_text" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            app:tint="@color/_____cancel_text"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/btn_copy_from_usb" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/btn_copy_to_usb"
            app:tint="@color/_____cancel_text" />

        <ImageView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:tint="@color/white"
            app:srcCompat="@drawable/cloud_ko" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_proj"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        app:layout_constraintBottom_toTopOf="@+id/divider48"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt2" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_in"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        app:layout_constraintBottom_toTopOf="@+id/guideline132"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt1" />


</androidx.constraintlayout.widget.ConstraintLayout>