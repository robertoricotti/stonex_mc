<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="gui.my_opengl.MyGLActivity_Create">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidLo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.92" />
    <android.opengl.GLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@id/guidLo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/_____cancel_text"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guidLo">

        <ImageView
            android:id="@+id/digMenu"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@drawable/custom_background_test3d_box_grigino"
            android:padding="5dp"
            android:rotation="180"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/menu_btn"
            app:tint="@color/black" />




        <ImageView
            android:id="@+id/bucketEdgeL"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/bucketEdgeC"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/bucketEdgeR"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/add_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/add_96"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/remove_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/remove_96"
            app:tint="@color/red" />


        <ImageView
            android:id="@+id/edit_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/btn_edit_list"
            app:tint="@color/orange" />

        <ImageView
            android:id="@+id/salva"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/save_btn" />




    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>