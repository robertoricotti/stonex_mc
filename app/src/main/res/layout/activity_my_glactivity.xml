<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="gui.my_opengl.MyGLActivity_Create">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidLo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.92" />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.94" />
    <gui.my_opengl.MyGLSurfaceView_Create
        android:id="@+id/glSurfaceViewCreate"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@id/guidLo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/_____cancel_text"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guidLo">

        <ImageView
            android:id="@+id/digMenu"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@drawable/custom_background_test3d_box_grigino"
            android:padding="5dp"
            android:rotation="180"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/menu_btn"
            app:tint="@color/black" />




        <ImageView
            android:id="@+id/bucketEdgeL"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/bucketEdgeC"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/bucketEdgeR"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/add_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/add_96"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/remove_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/remove_96"
            app:tint="@color/red" />


        <ImageView
            android:id="@+id/edit_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/btn_edit_list"
            app:tint="@color/orange" />

        <ImageView
            android:id="@+id/salva"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/save_btn" />




    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guidLo"
        android:background="@drawable/sfondo_bottone_grigio"
        >
        <ImageView
            android:id="@+id/gl_facce"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="2dp"
            android:rotation="180"
            android:src="@drawable/terrain_model"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/gl_fill"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="2dp"
            android:src="@drawable/fill_96"
            app:tint="@color/white" />



        <ImageView
            android:id="@+id/gl_poly"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="2dp"
            android:src="@drawable/polilinea"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/gl_point"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="2dp"
            android:src="@drawable/grigliapunti"
            app:tint="@color/white" />

        <ImageView

            android:id="@+id/gl_text"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="3dp"
            android:src="@drawable/btn_show_z"
            app:tint="@color/white" />
        <ImageView
            android:id="@+id/gl_2d3d"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="2dp"
            android:src="@drawable/duedi_vista"
            app:tint="@color/white" />

        <ImageView

            android:id="@+id/gpsStat"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginVertical="2dp"
            android:background="@drawable/custom_background_test3d"
            android:clickable="true"
            android:padding="3dp"
            android:src="@drawable/gnss_setup_btn"
            app:tint="@color/white" />

    </LinearLayout>
    <ImageView
        android:id="@+id/navigatorHDT"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@color/transparent"
        android:rotation="180"
        android:src="@drawable/stakeout_ref_north"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:tint="@color/white" />
    <ImageView
        android:id="@+id/statoImg"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="5dp"
        android:padding="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:background="@drawable/sfondo_bottone_grigio"
        android:src="@drawable/ab_piano_benna" />

    <TextView
        android:id="@+id/mostraCoor"
        android:layout_margin="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:text="WWWWWWW"
        app:layout_constraintTop_toBottomOf="@id/statoImg"
        app:layout_constraintLeft_toLeftOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>