<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:background="@color/_____cancel_text">

    <LinearLayout
        android:padding="1dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/img_1"
            android:background="@drawable/custom_bk_stonex_blue"
            android:layout_weight="1"
            android:layout_width="35dp"
            android:padding="5dp"
            android:layout_height="match_parent"
            android:src="@drawable/btn_key_license"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/img_2"
            android:background="@drawable/custom_bk_stonex_blue"
            android:layout_weight="1"
            android:layout_width="35dp"
            android:padding="5dp"
            android:layout_height="match_parent"
            android:src="@drawable/teck_lock"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/img_3"
            android:background="@drawable/custom_bk_stonex_blue"
            android:layout_weight="1"
            android:layout_width="35dp"
            android:padding="5dp"
            android:layout_height="match_parent"
            android:src="@drawable/wifi_vuoto"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/img_4"
            android:background="@drawable/custom_bk_stonex_blue"
            android:layout_weight="1"
            android:layout_width="35dp"
            android:padding="5dp"
            android:layout_height="match_parent"
            android:src="@drawable/gps_setup_ver02"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/img_5"
            android:background="@drawable/custom_bk_stonex_blue"
            android:layout_weight="1"
            android:layout_width="35dp"
            android:padding="5dp"
            android:layout_height="match_parent"
            android:src="@drawable/new_can_ok"
            app:tint="@color/white" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>