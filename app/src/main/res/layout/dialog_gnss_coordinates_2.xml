<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/custom_background_transp">

    <ImageView
        android:id="@+id/crsimg"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/custom_background_transp"
        android:gravity="center"
        android:padding="5dp"
        android:src="@drawable/imposta_coordinate"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/titleG"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/crstxt"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_vertical"
        android:textAlignment="inherit"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/titleG"
        app:layout_constraintLeft_toRightOf="@id/crsimg"
        app:layout_constraintRight_toLeftOf="@id/titleG"
        app:layout_constraintTop_toTopOf="@id/titleG"

        />


    <ImageView
        android:id="@+id/titleG"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/custom_background_transp"
        android:gravity="center"
        android:src="@drawable/gps_no"
        android:text="GNSS COORDINATES"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btBTconnect"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="50dp"
        android:layout_weight="0"
        android:background="@drawable/custom_background_transp"
        android:gravity="center"
        android:src="@drawable/bluetooth_disconnetti"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintLeft_toRightOf="@id/titleG"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/serialCon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="50dp"
        android:layout_weight="0"
        android:background="@drawable/custom_background_transp"
        android:gravity="center"
        android:src="@drawable/debug"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintLeft_toRightOf="@id/titleG"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/custom_background_light"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/_btnclose"
        app:layout_constraintTop_toBottomOf="@id/titleG">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:src="@drawable/sat_24" />

            <TextView
                android:id="@+id/txSat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:ems="6"
                android:gravity="left"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:src="@drawable/gps_fixed_24" />

            <TextView
                android:id="@+id/txfix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:ems="6"
                android:gravity="left"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:src="@drawable/rtk_24" />

            <TextView
                android:id="@+id/txage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:ems="6"
                android:gravity="left"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:src="@drawable/location_on_24" />

            <TextView
                android:id="@+id/txcq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:ems="6"
                android:gravity="left"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:src="@drawable/degrees_cw_24" />

            <TextView
                android:id="@+id/txmchdt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="10dp"
                android:ems="8"
                android:gravity="left"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txconnected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="10dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="10dp"
                android:gravity="center"
                android:src="@drawable/gps_setup" />

            <TextView
                android:id="@+id/txtant1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="2"
                android:ems="6"
                android:gravity="left|center_vertical"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imbl"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="10dp"
                android:gravity="center"
                android:src="@drawable/benna_misura_sinistra" />

            <TextView
                android:id="@+id/txtbennasx"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="2"
                android:ems="6"
                android:gravity="left|center_vertical"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imbc"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="10dp"
                android:gravity="center"
                android:src="@drawable/benna_misura_cnt" />

            <TextView
                android:id="@+id/txtbennacx"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="2"
                android:ems="6"
                android:gravity="left|center_vertical"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imbr"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_margin="10dp"
                android:gravity="center"
                android:src="@drawable/benna_misura_destra" />

            <TextView
                android:id="@+id/txtbennadx"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="2"
                android:ems="6"
                android:gravity="left|center_vertical"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1.5"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cqpiu"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/_____cancel_text"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvcq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/custom_background_light"
                android:ems="4"
                android:gravity="center"
                android:text="Max CQ\n0.000"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/cqmeno"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/_____cancel_text"
                android:text="-"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />


            <Button
                android:visibility="gone"
                android:id="@+id/rtkpiu"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/_____cancel_text"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:visibility="gone"
                android:id="@+id/tvrtk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/custom_background_light"
                android:ems="4"
                android:gravity="center"
                android:text="Max AGE\n5.0s"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:visibility="gone"
                android:id="@+id/rtkmeno"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/_____cancel_text"
                android:text="-"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />


            <Button
                android:visibility="gone"
                android:id="@+id/qtpiu"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/_____cancel_text"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:visibility="gone"
                android:id="@+id/tvqt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/custom_background_light"
                android:ems="4"
                android:gravity="center"
                android:text="TYPE\nFix"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:visibility="gone"
                android:id="@+id/qtmeno"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/_____cancel_text"
                android:text="-"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>


    <ImageView
        android:id="@+id/_btnclose"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:rotationY="180"
        android:src="@drawable/btn_close_web"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"

        app:tint="@color/_____cancel_text"
        android:visibility="invisible"/>

    <ImageView
        android:id="@+id/_btnSavex"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="2dp"
        android:src="@drawable/btn_close_web"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toLeftOf="@id/_btnclose"
        app:layout_constraintLeft_toRightOf="@id/_editZ"
        app:tint="@color/_____cancel_text"
         />
    <ImageView
        android:id="@+id/_editZ"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="2dp"
        android:src="@drawable/btn_benchmark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/_switchRadio"
        app:layout_constraintRight_toLeftOf="@id/_btnSavex"

        />

    <ImageView
        android:id="@+id/_switchRadio"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
       app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/_editZ"

        app:tint="@color/_____cancel_text"
        android:src="@drawable/sim_96"/>
    <ProgressBar
        android:id="@+id/progresss"
        android:layout_margin="50dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/transparentblack"

        />
    <LinearLayout
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginRight="10dp"
        android:paddingHorizontal="5dp"
        android:background="@drawable/custom_background_transp_2">
        <TextView
            android:layout_marginVertical="5dp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:text="SENSORS"/>
        <TextView
            android:layout_marginVertical="5dp"
            android:id="@+id/idframe"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:background="@color/red"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="FRAME"/>
        <TextView
            android:layout_marginVertical="5dp"
            android:id="@+id/idboom1"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:background="@color/red"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="BOOM 1"/>
        <TextView
            android:layout_marginVertical="5dp"
            android:id="@+id/idBoom2"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:background="@color/red"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="BOOM 2"/>
        <TextView
            android:layout_marginVertical="5dp"
            android:id="@+id/idStick"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:background="@color/red"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="STICK"/>
        <TextView
            android:layout_marginVertical="5dp"
            android:id="@+id/idbucket"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:background="@color/red"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="BUCKET"/>
        <TextView
            android:layout_marginVertical="5dp"
            android:id="@+id/idTilt"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:background="@color/red"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:text="TILT"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>