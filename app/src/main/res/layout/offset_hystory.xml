<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/custom_background_light"
    android:padding="5dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center|top"

       >
        <TextView
            android:id="@+id/tit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="22sp"
            android:text="OFFSET HYSTORY"
            android:textStyle="bold"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"/>

        <LinearLayout
            android:id="@+id/l_offset1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="5dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ems="6"
                android:gravity="center"
                android:text="OFFSET 1"/>
            <TextView
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:background="@color/_____cancel_text"/>
            <TextView
                android:id="@+id/off_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ems="6"
                android:gravity="center"
                android:text="0.000"
                />

        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/_____cancel_text"/>

        <LinearLayout
            android:id="@+id/l_offset2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="5dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ems="6"
                android:gravity="center"
                android:text="OFFSET 2"/>
            <TextView
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:background="@color/_____cancel_text"/>
            <TextView
                android:id="@+id/off_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ems="6"
                android:gravity="center"
                android:text="0.000"
                />

        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/_____cancel_text"/>
        <LinearLayout
            android:id="@+id/l_offset3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="5dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ems="6"
                android:gravity="center"
                android:text="OFFSET 3"/>
            <TextView
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:background="@color/_____cancel_text"/>
            <TextView
                android:id="@+id/off_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ems="6"
                android:gravity="center"
                android:text="0.000"
                />

        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/_____cancel_text"/>





    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>