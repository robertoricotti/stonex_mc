<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sfondo_dialog_scura"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/hc0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.375"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/hc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.75"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/vc1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3333"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/vc2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6666"/>

    <ImageView
        android:id="@+id/usb"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sfondo_bottone_bianco"
        android:src="@drawable/bottone_usb_transf"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hc0"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/vc1"
        android:layout_margin="15dp"/>
    <ImageView
        android:id="@+id/flat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sfondo_bottone_bianco"
        android:src="@drawable/bottone_flat_infinite"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hc0"
        app:layout_constraintLeft_toRightOf="@id/vc1"
        app:layout_constraintRight_toLeftOf="@id/vc2"
        android:layout_margin="15dp"
        android:padding="5dp"
        />
    <ImageView
        android:id="@+id/ab"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sfondo_bottone_bianco"
        android:src="@drawable/bottone_ab"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hc0"
        app:layout_constraintLeft_toRightOf="@id/vc2"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_margin="15dp"
        android:padding="5dp"
        />
    <ImageView
        android:id="@+id/flatarea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sfondo_bottone_bianco"
        android:src="@drawable/bottone_area"
        app:layout_constraintTop_toBottomOf="@id/hc0"
        app:layout_constraintBottom_toTopOf="@id/hc"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/vc1"
        android:layout_margin="15dp"
        android:padding="5dp"
        />
    <ImageView
        android:id="@+id/trench"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sfondo_bottone_bianco"
        android:src="@drawable/bottone_trench"
        app:layout_constraintTop_toBottomOf="@id/hc0"
        app:layout_constraintBottom_toTopOf="@id/hc"
        app:layout_constraintLeft_toRightOf="@id/vc1"
        app:layout_constraintRight_toLeftOf="@id/vc2"
        android:layout_margin="15dp"
        android:padding="5dp"
        />
    <ImageView
        android:id="@+id/terrein"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sfondo_bottone_bianco"
        android:src="@drawable/bottone_triangoli"
        app:layout_constraintTop_toBottomOf="@id/hc0"
        app:layout_constraintBottom_toTopOf="@id/hc"
        app:layout_constraintLeft_toRightOf="@id/vc2"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_margin="15dp"
        android:padding="0dp"
        />



    <ImageView
        android:id="@+id/cancel"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/btn_close_web"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
       />
</androidx.constraintlayout.widget.ConstraintLayout>