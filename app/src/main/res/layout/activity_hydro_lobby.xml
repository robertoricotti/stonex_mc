<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="gui.debug_ecu.Hydro_Lobby">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/v_uno"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.333" />
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/v_due"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.666" />
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/mezzoH"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.44" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.89" />
    <ImageButton
        android:id="@+id/normal_hydro"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/mezzoH"
        app:layout_constraintRight_toLeftOf="@id/v_uno"
        android:layout_margin="25dp"
        android:scaleType="centerInside"
        android:background="@drawable/custom_background_light"
        android:src="@drawable/btn_valvole"
        />
    <ImageButton
        android:id="@+id/joy_interfce"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/v_uno"
        app:layout_constraintBottom_toTopOf="@id/mezzoH"
        app:layout_constraintRight_toLeftOf="@id/v_due"
        android:layout_margin="25dp"
        android:scaleType="centerInside"
        android:background="@drawable/custom_background_light"
        android:src="@drawable/btn_joystick"
        />
    <ImageButton
        android:id="@+id/cat_can"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/v_due"
        app:layout_constraintBottom_toTopOf="@id/mezzoH"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_margin="55dp"
        android:padding="10dp"
        android:alpha="0.3"
        android:scaleType="centerInside"
        android:background="@color/light_gray"
        android:src="@drawable/cat_can"

        />
    <ImageButton
        android:id="@+id/john_deere"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mezzoH"
        app:layout_constraintBottom_toTopOf="@id/guideLow"
        app:layout_constraintRight_toLeftOf="@id/v_uno"
        android:layout_margin="55dp"
        android:padding="10dp"
        android:alpha="0.3"
        android:scaleType="centerInside"
        android:background="@color/light_gray"
        android:src="@drawable/johndeere"

        />
    <ImageButton
        android:id="@+id/komatsu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toRightOf="@id/v_uno"
        app:layout_constraintTop_toBottomOf="@id/mezzoH"
        app:layout_constraintBottom_toTopOf="@id/guideLow"
        app:layout_constraintRight_toLeftOf="@id/v_due"
        android:layout_margin="55dp"
        android:padding="10dp"
        android:alpha="0.3"
        android:scaleType="centerInside"
        android:background="@color/light_gray"
        android:src="@drawable/komatsucan"

        />
    <ImageButton
        android:id="@+id/case_cnh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mezzoH"
        app:layout_constraintBottom_toTopOf="@id/guideLow"
        app:layout_constraintLeft_toRightOf="@id/v_due"
        android:layout_margin="55dp"
        android:padding="10dp"
        android:alpha="0.3"
        android:scaleType="centerInside"
        android:background="@color/light_gray"
        android:src="@drawable/komatsucan"
        app:tint="@color/light_gray"
        />
    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:background="@color/nav_gray_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideLow">

        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"

            android:background="@drawable/custom_background_test3d"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:rotation="180"
            android:src="@drawable/menu_btn"
            app:tint="@color/white"/>


        <ImageView
            android:id="@+id/ecustatus"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d"
            android:padding="1dp"
            />




    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>