<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.09" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/botla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.89" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/topla"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img00"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/gnss_setup_btn"
            app:tint="@color/white" />

        <ImageView

            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/gnss_setup_btn"
            app:tint="@color/transparent" />

        <EditText
            android:id="@+id/mch_name"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="italic" />

        <ImageView
            android:id="@+id/img01"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/bottone_save_mch"
            app:tint="@color/_____cancel_text" />

        <ImageView
            android:id="@+id/img11"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/bottone_call_mch"
            app:tint="@color/_____cancel_text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/custom_background_test3d_box"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/botla">

        <ImageView
            android:id="@+id/btn_1"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="5dp"
            android:rotation="180"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/menu_btn"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/imgMove"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="4"
            android:padding="15dp"
            android:scaleType="centerInside" />

        <ImageView
            android:id="@+id/deleteFile"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/delete_raw"
            android:visibility="invisible"
            app:tint="@color/white"

            />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="4"
            android:padding="15dp"
            android:scaleType="centerInside" />

        <ImageView
            android:id="@+id/btn_3"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/info_96"
            app:tint="@color/_____cancel_text" />

        <ImageView
            android:id="@+id/btn_2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/teck_lock"
            app:tint="@color/_____cancel_text" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/botla"
        app:layout_constraintTop_toBottomOf="@id/topla">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginVertical="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/sel_exca"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/machines_btn" />

                <ImageView
                    android:id="@+id/sel_wheel"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/wheel_machines_btn" />

                <ImageView
                    android:id="@+id/sel_dozer"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/dozer_machines_btn" />

                <ImageView
                    android:id="@+id/sel_grader"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/grader_btn" />


            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/_____cancel_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/light_gray"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/bt_menu1"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_arrow_down_96" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/general_set"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_arrow_down_96"
                    app:tint="@color/transparent" />

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint_general"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="15dp"
                android:visibility="gone">
                <CheckBox
                    android:id="@+id/ckSchermo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/_____cancel_text"
                    android:text="ENABLE ANDROID NAVIGATION BUTTONS"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <CheckBox
                    android:id="@+id/ck2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/_____cancel_text"
                    android:text="DIGITAL OUTPUT 12V"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ckSchermo"  />

                <CheckBox
                    android:id="@+id/ck3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/_____cancel_text"
                    android:text="SWITCH UHF/NTRIP"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ck2" />

                <CheckBox
                    android:id="@+id/ck4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/_____cancel_text"
                    android:text="UPPER BAR ALWAYS VISIBLE IN WORKING PAGE"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ck3" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/_____cancel_text"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ck4" />

                <CheckBox
                    android:id="@+id/ck5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/_____cancel_text"
                    android:text="SENSOR TYPE STX IMU"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ck4" />

                <CheckBox
                    android:id="@+id/ck6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/_____cancel_text"
                    android:text="SENSOR TYPE DEMO BAG"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="18sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ck5" />

                <View
                    android:id="@+id/brake"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/_____cancel_text"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ck6" />

                <EditText
                    android:id="@+id/techInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusableInTouchMode="false"
                    android:gravity="center"
                    android:textStyle="bold|italic"
                    app:layout_constraintTop_toBottomOf="@id/brake"
                    android:textSize="22sp"
                    android:textAllCaps="false"
                    android:textColor="@color/_____cancel_text"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/_____cancel_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/light_gray"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/bt_sens_set"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_arrow_down_96" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/mac_setup"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_arrow_down_96"
                    app:tint="@color/transparent" />

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constr_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="5dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/toFrame"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="FRAME"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toBoom1"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="BOOM 1"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toBoom2"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="BOOM 2"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toStick"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="STICK - LASER"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toDogBone"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="LINKAGE - BUCKET"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toTilt"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="TILT"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toxyz"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="ΔX ΔY ΔZ"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />


                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/_____cancel_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/light_gray"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/bt_canopen"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_arrow_down_96" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/sens_config"
                    android:textColor="@color/_____cancel_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_arrow_down_96"
                    app:tint="@color/transparent" />

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constr_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/toCanOpen"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/light_yellow"
                        android:ems="15"
                        android:gravity="center"
                        android:text="CAN-OPEN SETUP"
                        android:textColor="@color/_____cancel_text"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toDamping"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/red"
                        android:ems="15"
                        android:gravity="center"
                        android:text="SENSORS SPEED"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toCan1"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="CAN 1 Baudrate"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/toCan2"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginVertical="5dp"
                        android:background="@color/bg_stonex_blue"
                        android:ems="15"
                        android:gravity="center"
                        android:text="CAN 2 Baudrate"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />


                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/_____cancel_text" />
        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>