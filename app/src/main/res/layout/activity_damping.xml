                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_weight="0"/>

        </LinearLayout>
        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:ems="10"
