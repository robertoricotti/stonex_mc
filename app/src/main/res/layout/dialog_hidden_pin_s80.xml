<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/mainayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"

        app:layout_constraintBottom_toTopOf="@id/calcol"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MEASURE 1"
            android:gravity="center"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18px"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <EditText
                android:id="@+id/et_x1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="X_1"
                android:focusableInTouchMode="false"
                android:maxLines="1"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:imeOptions="actionDone"
                android:textColor="@color/_____cancel_text"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_weight="1"/>
            <EditText
                android:id="@+id/et_y1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Y_1"
                android:focusableInTouchMode="false"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:textColor="@color/_____cancel_text"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_weight="1"/>

        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MEASURE 2"
            android:gravity="center"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18px"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <EditText
                android:id="@+id/et_x2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="X_2"
                android:focusableInTouchMode="false"
                android:textColor="@color/_____cancel_text"
                android:textStyle="bold"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:gravity="center"
                android:layout_weight="1"/>
            <EditText
                android:id="@+id/et_y2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Y_2"
                android:focusableInTouchMode="false"
                android:textColor="@color/_____cancel_text"
                android:textStyle="bold"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:gravity="center"
                android:layout_weight="1"/>
        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MEASURE 3"
            android:gravity="center"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18px"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <EditText
                android:id="@+id/et_x3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="X_3"
                android:focusableInTouchMode="false"
                android:textColor="@color/_____cancel_text"
                android:textStyle="bold"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:gravity="center"
                android:layout_weight="1"/>
            <EditText
                android:id="@+id/et_y3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Y_3"
                android:focusableInTouchMode="false"
                android:textColor="@color/_____cancel_text"
                android:textStyle="bold"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:gravity="center"
                android:layout_weight="1"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="5dp"
            >
            <TextView

                android:id="@+id/txt_result_m"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minEms="5"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="24px"/>
            <TextView
                android:text="  "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:textSize="24px"/>
            <TextView

                android:id="@+id/txt_result_ft"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minEms="5"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="24px"/>
            <TextView
                android:text="  "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:textSize="24px"/>
            <TextView

                android:id="@+id/txt_result_deg"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minEms="5"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="24px"/>


        </LinearLayout>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/esca_3pt"/>

    </LinearLayout>

    <Button
        android:id="@+id/calcol"
        android:layout_width="130px"
        android:layout_height="70px"
        android:backgroundTint="@color/blue"
        android:gravity="center"
        android:text="CALC"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="20px"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/mainayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/esci" />

    <Button
        android:id="@+id/esci"
        android:layout_width="130px"
        android:layout_height="70px"
        android:backgroundTint="@color/_____cancel_text"
        android:gravity="center"
        android:text="EXIT"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="20px"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/mainayout"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/calcol"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>