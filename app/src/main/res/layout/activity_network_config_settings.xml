<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/CustomProgressBar"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        android:alpha="0.7"
        android:background="@color/_____cancel_text"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.09" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/botla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.89" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/topla"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img00"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/baseline_signal_wifi_statusbar_4_bar_96"
            app:tint="@color/white" />


        <TextView
            android:id="@+id/mch_name"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="italic" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/custom_background_test3d_box"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/botla">

        <ImageView
            android:id="@+id/btn_1"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="5dp"
            android:rotation="180"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/menu_btn"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/imgMove"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="4"
            android:padding="15dp"
            android:scaleType="centerInside" />



        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="4"
            android:padding="15dp"
            android:scaleType="centerInside" />


        <ImageView
            android:id="@+id/btn_3"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="1dp"
            android:scaleType="center"
            android:src="@drawable/monitor_rs_full_transparent"
            app:tint="@color/white" />
        <ImageView
            android:visibility="invisible"
            android:id="@+id/debugSerial"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="1dp"
            android:scaleType="center"
            android:src="@drawable/monitor_can_full_transparent"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/btn_2"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/save_mch"
            app:tint="@color/white" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fadeScrollbars="false"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:scrollbarFadeDuration="0"
        android:scrollbarSize="24dp"
        app:layout_constraintBottom_toTopOf="@id/botla"
        app:layout_constraintTop_toBottomOf="@id/topla">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginVertical="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/sel_wifi"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:gravity="center"
                    android:text="WIFI"
                    android:textAlignment="center"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sel_sim"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:gravity="center"
                    android:text="SIM"
                    android:textAlignment="center"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sel_gnss_type"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:gravity="center"
                    android:text="TYPE GNSS"
                    android:textAlignment="center"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sel_ntrip"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:gravity="center"
                    android:text="NTRIP SERVER"
                    android:textAlignment="center"
                    android:textStyle="bold" />


                <TextView
                    android:id="@+id/sel_nmea_rate"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/sfondo_bottone_trasparente"
                    android:gravity="center"
                    android:text="NMEA RATE"
                    android:textAlignment="center"
                    android:textStyle="bold" />


            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:background="@color/bg_gray" />


            <!-- MENU WIFI -->
            <LinearLayout
                android:id="@+id/wifi_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="vertical"
                android:visibility="gone">
                <!-- Riga 1 - Normale -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    android:gravity="center|start"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btn_wifi_settings"
                        style="@style/TextAppearance.AppCompat.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/bg_sfsblue"
                        android:text="WIFI SETTINGS"
                        android:textColor="@color/white" />
                </LinearLayout>


            </LinearLayout>

            <!-- MENU SIM -->
            <LinearLayout
                android:id="@+id/sim_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="vertical"
                android:visibility="gone">
                <!-- Riga 1 - Normale -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    android:gravity="center|start"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btn_sim_settings"
                        style="@style/TextAppearance.AppCompat.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/bg_sfsblue"
                        android:text="SIM SETTINGS"
                        android:textColor="@color/white" />
                </LinearLayout>


            </LinearLayout>

            <!-- MENU GNSS TYPE -->
            <LinearLayout
                android:id="@+id/gnss_type_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Riga 1 - Grigia -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    android:gravity="center|start"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="TYPE GNSS"
                        android:textSize="18sp" />

                    <RadioGroup
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/internal_gnss"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Internal"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/demo_gnss"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:text="DEMO"
                            android:textSize="18sp" />
                    </RadioGroup>
                </LinearLayout>


            </LinearLayout>

            <!-- MENU NTRIP CLIENT -->
            <!-- MENU NTRIP CLIENT -->
            <LinearLayout
                android:id="@+id/ntrip_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Riga 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    android:gravity="center|start"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Enable"
                        android:textSize="18sp" />

                    <RadioGroup
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/ntrip_enable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="On"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/ntrip_disable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:text="Off"
                            android:textSize="18sp" />
                    </RadioGroup>
                </LinearLayout>

                <!-- WRAPPER da Host a Password -->
                <LinearLayout
                    android:id="@+id/ntrip_credentials_wrapper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Riga 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:gravity="center|start"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Host"
                            android:textSize="18sp" />

                        <EditText
                            android:id="@+id/ntrip_host_ip"
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_border"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:text=""
                            android:textSize="18sp" />
                    </LinearLayout>

                    <!-- Riga 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:gravity="center|start"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Port"
                            android:textSize="18sp" />

                        <EditText
                            android:id="@+id/ntrip_port"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_border"
                            android:imeOptions="actionDone"
                            android:inputType="number"
                            android:text=""
                            android:textSize="18sp" />
                    </LinearLayout>

                    <!-- Riga 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:gravity="center|start"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Mountpoint"
                            android:textSize="18sp" />

                        <EditText
                            android:id="@+id/ntrip_mountpoint"
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_border"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:inputType="text"
                            android:text=""
                            android:textSize="18sp" />

                        <Button
                            android:id="@+id/btn_get_mountpoint"
                            style="@style/TextAppearance.AppCompat.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:backgroundTint="@color/bg_sfsblue"
                            android:text="Get Mountpoint"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Riga 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:gravity="center|start"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Upload GGA"
                            android:textSize="18sp" />

                        <EditText
                            android:id="@+id/ntrip_gga"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_border"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:inputType="text"
                            android:text=""
                            android:textSize="18sp" />

                        <Button
                            android:id="@+id/btn_get_upload_gga"
                            style="@style/TextAppearance.AppCompat.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:backgroundTint="@color/bg_sfsblue"
                            android:text="Get Upload GGA"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- Riga 6 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:gravity="center|start"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="User"
                            android:textSize="18sp" />

                        <EditText
                            android:id="@+id/ntrip_username"
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_border"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:text=""
                            android:textSize="18sp" />
                    </LinearLayout>

                    <!-- Riga 7 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:gravity="center|start"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Password"
                            android:textSize="18sp" />

                        <EditText
                            android:id="@+id/ntrip_password"
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_border"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:text=""
                            android:textSize="18sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- MENU NMEA RATE -->
            <LinearLayout
                android:id="@+id/nmea_rate_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Riga 1 - Grigia -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    android:gravity="center|start"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Enable"
                        android:textSize="18sp" />

                    <RadioGroup
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/nmea_rate_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/nmea_rate_5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:text="5"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/nmea_rate_10"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:text="10"
                            android:textSize="18sp" />

                        <RadioButton
                            android:id="@+id/nmea_rate_20"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:text="20"
                            android:textSize="18sp" />
                    </RadioGroup>
                </LinearLayout>

            </LinearLayout>


        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>