                app:srcCompat="@drawable/gnss_setup_btn"
                app:tint="@color/_____cancel_text" />

            <ImageView
                android:id="@+id/gotoBuck4"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:background="@drawable/sfondo_bottone_trasparente"
                android:padding="15dp"
                app:srcCompat="@drawable/benna_vuota1"
