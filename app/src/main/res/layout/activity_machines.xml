            <ImageView
                android:id="@+id/modify_mac_4"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:background="@drawable/sfondo_bottone_trasparente"
                android:padding="15dp"
                app:srcCompat="@drawable/button_go_tech_menu"
                app:tint="@color/_____cancel_text" />
        </LinearLayout>
    </LinearLayout>

