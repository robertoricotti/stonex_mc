<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sfondo_bottone_grigio"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/menuTitle"
        android:background="@color/bg_stonex_blue"
        android:layout_width="match_parent"
        android:layout_height="55sp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>


    <ListView
        android:id="@+id/listView"
        android:foregroundTint="@color/white"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/menuTitle"
        android:backgroundTint="@color/light_gray"
        app:layout_constraintTop_toBottomOf="@id/menuTitle"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>


<ImageView
    android:id="@+id/chiudi"
    android:layout_width="55dp"
    android:layout_height="0dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="@id/menuTitle"
    app:layout_constraintRight_toRightOf="parent"
    android:src="@drawable/close_web"
    app:tint="@color/white"
    android:padding="1dp"
    />

</androidx.constraintlayout.widget.ConstraintLayout>