<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sfondo_dialog_chiara"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/hc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.8"/>

    <ImageView
        android:id="@+id/remove"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/delete_raw"
        android:background="@drawable/sfondo_bottone_trasparente"
        app:layout_constraintLeft_toRightOf="@id/lista"
        app:layout_constraintRight_toLeftOf="@id/cancel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        android:padding="2dp"
       app:tint="@color/_____cancel_text"

        />

    <ImageView
        android:id="@+id/lista"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/key_arrow_right"
        android:background="@drawable/sfondo_bottone_trasparente"


        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/remove"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        app:tint="@color/_____cancel_text"

        />
    <ImageView
        android:id="@+id/cancel"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/btn_close_web"
        app:layout_constraintLeft_toRightOf="@id/remove"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        app:tint="@color/_____cancel_text"
        />

    <!-- Contenitore personalizzato con LinearLayout -->


        <LinearLayout
            android:id="@+id/customLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/hc">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="18sp"
                android:layout_margin="2dp"
                android:background="@color/_____cancel_text"
                android:text="PNEZD File Name"
                android:textColor="@color/white"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvPath"
                android:gravity="center"
                android:textSize="18sp"
                android:paddingVertical="10dp"
                android:layout_margin="2dp"
                android:background="@color/white"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="18sp"
                android:layout_margin="2dp"
                android:background="@color/_____cancel_text"
                android:text="Tool Coordinates"
                android:textColor="@color/white"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvCoord"
                android:gravity="center"
                android:textSize="18sp"
                android:paddingVertical="10dp"
                android:layout_margin="2dp"
                android:background="@color/white"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="18sp"
                android:layout_margin="2dp"
                android:background="@color/_____cancel_text"
                android:text="Description"
                android:textColor="@color/white"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/descr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="20sp"
                android:layout_margin="2dp"
                android:textStyle="bold|italic"
                android:gravity="center"
                android:hint=""
                android:focusableInTouchMode="false"
                android:background="@color/white"/>
            <TextView
                android:id="@+id/pnezd_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_weight="0.5"
                android:textSize="20sp"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:background="@color/_____cancel_text"
                android:text="Point Color"
                android:textColor="@color/white"
                android:textStyle="bold"/>
            <ImageView
                android:id="@+id/save"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/add_96"
                android:layout_weight="0.5"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                app:tint="@color/blue"
                android:background="@drawable/sfondo_bottone_bianco"

                />
        </LinearLayout>




    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pointsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@color/white"
        android:padding="5dp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hc" />
</androidx.constraintlayout.widget.ConstraintLayout>