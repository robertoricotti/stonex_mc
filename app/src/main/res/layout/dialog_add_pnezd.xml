<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sfondo_dialog_chiara"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/hc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.8"/>
    <ImageView
        android:id="@+id/save"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/add_96"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/remove"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        app:tint="@color/blue"
        />
    <ImageView
        android:id="@+id/remove"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/remove_96"
        app:layout_constraintLeft_toRightOf="@id/save"
        app:layout_constraintRight_toLeftOf="@id/lista"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        app:tint="@color/red"
        />

    <ImageView
        android:id="@+id/lista"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/view_btn"
        app:layout_constraintLeft_toRightOf="@id/remove"
        app:layout_constraintRight_toLeftOf="@id/cancel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        app:tint="@color/_____cancel_text"

        />
    <ImageView
        android:id="@+id/cancel"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/btn_close_web"
        app:layout_constraintLeft_toRightOf="@id/lista"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hc"
        app:tint="@color/_____cancel_text"
        />

    <!-- Contenitore personalizzato con LinearLayout -->
    <ScrollView
        android:id="@+id/customViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hc">

        <LinearLayout
            android:id="@+id/customLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>
    <!-- RecyclerView per la lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pointsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        android:background="@color/white"
        android:padding="5dp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/hc" />
</androidx.constraintlayout.widget.ConstraintLayout>