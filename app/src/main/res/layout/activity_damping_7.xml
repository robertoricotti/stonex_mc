<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:keepScreenOn="true"
    tools:context="gui.tech_menu.DampingActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.09" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline15"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.89" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/guideline10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView

            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginBottom="2dp"
            android:layout_weight="4"
            android:background="@drawable/custom_background_test3d_box"
            android:gravity="center"
            android:text="SENSORS DAMPING"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />


    </LinearLayout>

    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline15">

        <ImageView
            android:id="@+id/_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/menu_btn"
            android:rotation="180"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/readAlli"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="6"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/btn_refresh"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/sendMsg"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/custom_background_test3d_box"
            android:padding="5dp"
            android:src="@drawable/bottone_save_mch"
            app:tint="@color/white" />


    </LinearLayout>

    <TextView
        android:id="@+id/img1"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:ems="12"
        android:padding="10dp"
        android:layout_height="0dp"
        android:textColor="@color/_____cancel_text"
        android:textStyle="italic"
        android:textSize="17sp"
        app:layout_constraintTop_toBottomOf="@id/guideline10"
        app:layout_constraintBottom_toTopOf="@id/guideline15"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/lay1" />

    <LinearLayout
        android:id="@+id/lay1"
        android:layout_marginTop="10dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginHorizontal="5dp"
        app:layout_constraintTop_toBottomOf="@id/guideline10"
        app:layout_constraintBottom_toTopOf="@id/guideline15"
        app:layout_constraintLeft_toRightOf="@id/img1"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:ems="8"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="FRAME SENSOR DAMPING"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:gravity="center"
                android:textSize="16sp" />

            <Button
                android:id="@+id/plus_fr"
                android:backgroundTint="@color/blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tx_fr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:textColor="@color/_____cancel_text"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp" />

            <Button

                android:id="@+id/min_fr"
                android:backgroundTint="@color/_____cancel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:ems="8"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="BOOM 1 SENSOR DAMPING"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:gravity="center"
                android:textSize="16sp" />

            <Button
                android:id="@+id/plus_b1"
                android:backgroundTint="@color/blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tx_b1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:textColor="@color/_____cancel_text"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp" />

            <Button


                android:id="@+id/min_b1"
                android:backgroundTint="@color/_____cancel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:ems="8"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="BOOM 2 SENSOR DAMPING"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:gravity="center"
                android:textSize="16sp" />

            <Button
                android:id="@+id/plus_b2"
                android:backgroundTint="@color/blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tx_b2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:textColor="@color/_____cancel_text"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp" />

            <Button


                android:id="@+id/min_b2"
                android:backgroundTint="@color/_____cancel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:ems="8"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="STICK SENSOR DAMPING"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:gravity="center"
                android:textSize="16sp" />

            <Button
                android:id="@+id/plus_st"
                android:backgroundTint="@color/blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tx_st"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:textColor="@color/_____cancel_text"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp" />

            <Button


                android:id="@+id/min_st"
                android:backgroundTint="@color/_____cancel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:ems="8"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="BUCKET SENSOR DAMPING"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:gravity="center"
                android:textSize="16sp" />

            <Button
                android:id="@+id/plus_bk"
                android:backgroundTint="@color/blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tx_bk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:textColor="@color/_____cancel_text"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp" />

            <Button


                android:id="@+id/min_bk"
                android:backgroundTint="@color/_____cancel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginVertical="5dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:ems="8"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="TILT BUCKET SENSOR DAMPING"
                android:textStyle="bold"
                android:textColor="@color/_____cancel_text"
                android:gravity="center"
                android:textSize="16sp" />

            <Button
                android:id="@+id/plus_tl"
                android:backgroundTint="@color/blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <TextView
                android:id="@+id/tx_tl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="10"
                android:textColor="@color/_____cancel_text"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp"

                />

            <Button
                android:id="@+id/min_tl"
                android:backgroundTint="@color/_____cancel_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="0" />

        </LinearLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>