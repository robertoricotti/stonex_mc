<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstr"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/add_text"
    android:keepScreenOn="true">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/vert_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/hor_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.88" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline17_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.88" />


    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/_____cancel_text"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideLow">

        <ImageView
            android:id="@+id/uscita"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="1.5dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/back_exit_96" />

        <ImageView
            android:id="@+id/bucketEdgeL"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />
        <ImageView
            android:id="@+id/bucketEdgeC"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />
        <ImageView
            android:id="@+id/bucketEdgeR"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/benna_misura_cnt" />

        <ImageView
            android:id="@+id/add_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/add_96"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/remove_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/remove_96"
            app:tint="@color/red"/>




        <ImageView
            android:id="@+id/edit_point"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/btn_edit_list"
            app:tint="@color/orange"/>

        <ImageView
            android:id="@+id/salva"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:paddingHorizontal="5dp"
            android:paddingVertical="15dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/save_btn" />


    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline19"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel3D"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg_gray"
        app:layout_constraintBottom_toTopOf="@+id/guideLow"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="@id/guideline19"
        app:layout_constraintTop_toTopOf="parent">

    </androidx.constraintlayout.widget.ConstraintLayout>







    <LinearLayout
        android:id="@+id/barleft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/_____cancel_text"
        android:orientation="vertical"
        android:paddingHorizontal="2.5dp"
        app:layout_constraintBottom_toTopOf="@+id/guideLow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline19"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/units"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/measuring"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/colori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/btn_colors"
            app:tint="@color/white" />


        <ImageView
            android:id="@+id/gpsInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/btn_gps_setup"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/zoomC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:rotation="45"
            android:src="@drawable/vertical_center_btn"
            app:tint="@color/white" />

        <ImageView

            android:id="@+id/zoomM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/zoom_out_btn"
            app:tint="@color/white" />

        <ImageView

            android:id="@+id/zoomP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/zoom_in_btn"
            app:tint="@color/white" />

    </LinearLayout>


    <ImageView
        android:id="@+id/bussola"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:src="@drawable/stakeout_ref_north"
        android:layout_margin="20dp"
        app:layout_constraintRight_toLeftOf="@id/barleft"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/blue" />
    <ImageView
        android:id="@+id/alertGnss"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@color/yellow"
        android:src="@drawable/gps_no"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ImageView
        android:id="@+id/statoImg"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:src="@drawable/ab_piano_benna"/>
    <TextView
        android:id="@+id/mostraCoor"
        android:layout_margin="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:text="WWWWWWW"
        app:layout_constraintTop_toBottomOf="@id/statoImg"
        app:layout_constraintLeft_toLeftOf="parent"/>
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/CustomProgressBar"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        android:alpha="0.7"
        android:background="@color/_____cancel_text"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/guideLow"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>