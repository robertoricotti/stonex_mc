<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="@color/light_blue_900"

    tools:context="gui.e_bubble.E_Bubble">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline21"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.1" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/midup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.35" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/middw"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6" />

    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.88" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelinew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.2" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline23"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <ImageView
        android:id="@+id/cent_target"
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/guideline21"
        app:layout_constraintBottom_toTopOf="@id/guideline23"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:src="@drawable/ebub_btn"
        app:tint="@color/light_gray" />

    <TextView
        android:id="@+id/txt_q"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="\t\t⧗ 0.00"
        android:textColor="@color/gray"
        android:textSize="60sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@id/guidelinew"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_X"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="\tX: -00.0°"
        android:gravity="center"
        android:textSize="60sp"
        android:textColor="@color/whiteGray"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/middw"
        app:layout_constraintTop_toBottomOf="@id/midup" />

    <TextView
        android:id="@+id/txt_Y"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="Y: -00.0°"
        android:gravity="center"
        android:textSize="60sp"
        android:textColor="@color/whiteGray"
        android:textStyle="bold"
        app:layout_constraintLeft_toRightOf="@id/centV"
        app:layout_constraintBottom_toTopOf="@id/guidelinew"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_r"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="r:-00.00"
        android:gravity="center"
        android:textSize="60sp"
        android:textColor="@color/whiteGray"
        android:textStyle="bold"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/guideline23" />

    <ImageView
        android:id="@+id/bubble"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:alpha="0.8"
        android:translationX="0dp"
        android:translationY="0dp"
        android:scaleType="centerInside"
        android:src="@drawable/cyrcle_colored"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline21"
        app:layout_constraintBottom_toTopOf="@id/guideline23"
        app:tint="@color/bg_sfsgreen" />

    <CheckBox
        android:id="@+id/ck_useTilt"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="@string/use_tilt"
        android:textColor="@color/light_gray"
        android:textSize="30sp"
        android:textStyle="bold"
        android:buttonTint="@color/light_gray"
        app:layout_constraintBottom_toTopOf="@id/ck_useBucket"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_margin="20dp"

        />

    <CheckBox
        android:id="@+id/ck_useBucket"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="@string/use_bucket"
        android:textColor="@color/light_gray"
        android:textSize="30sp"
        android:textStyle="bold"
        android:buttonTint="@color/light_gray"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline23"
        android:layout_margin="20dp"

        />


    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline23">

        <ImageView
            android:id="@+id/toMain_b"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="#D6D7DC"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/back_btn" />


        <ImageView
            android:id="@+id/moreDb"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0"
            android:background="#D6D7DC"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/up_btn"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/txtdb"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="0.5°"
            android:gravity="center"
            android:textSize="35sp"
            android:background="#D6D7DC"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:textColor="@color/_____cancel_text"
            android:textStyle="bold"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/lessDb"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="0"
            android:background="#D6D7DC"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/down_btn"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/setZeroEbub"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="#D6D7DC"
            android:padding="5dp"
            android:src="@drawable/target_btn_rotated"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/setZeroQuota"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="#D6D7DC"
            android:padding="5dp"
            android:src="@drawable/zero_btn"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/setLaser"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="#D6D7DC"
            android:padding="5dp"
            android:src="@drawable/laser_off_btn"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1" />


    </LinearLayout>

    <ImageView
        android:id="@+id/ebubleerr"
        android:visibility="visible"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:background="@color/yellow"
        android:rotation="45"
        android:src="@drawable/tsm_uno_rsized" />

</androidx.constraintlayout.widget.ConstraintLayout>