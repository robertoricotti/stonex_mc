<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray">


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/sopra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.1" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/medio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.2" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/v1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.333" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/v2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.666" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/sotto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/_____cancel_text"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/sopra"
        app:layout_constraintBottom_toBottomOf="@id/sopra" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/_____cancel_text"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/medio"
        app:layout_constraintBottom_toBottomOf="@id/medio" />

    <View
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/_____cancel_text"
        app:layout_constraintLeft_toLeftOf="@id/v1"
        app:layout_constraintRight_toRightOf="@id/v1"
        app:layout_constraintTop_toTopOf="@id/sopra"
        app:layout_constraintBottom_toBottomOf="@id/sotto" />

    <View
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/_____cancel_text"
        app:layout_constraintLeft_toLeftOf="@id/v2"
        app:layout_constraintRight_toRightOf="@id/v2"
        app:layout_constraintTop_toTopOf="@id/sopra"
        app:layout_constraintBottom_toBottomOf="@id/sotto" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/v1"
        app:layout_constraintTop_toBottomOf="@id/sopra"
        app:layout_constraintBottom_toTopOf="@id/medio"
        android:gravity="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:text="1D / 2D"
        android:textColor="@color/_____cancel_text" />

    <ImageView
        android:padding="50dp"
        android:id="@+id/mioQr"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/medio"
        app:layout_constraintBottom_toTopOf="@id/sotto"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/v1"
        android:src="@drawable/qr_quick_guide" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toRightOf="@id/v1"
        app:layout_constraintRight_toLeftOf="@id/v2"
        app:layout_constraintTop_toBottomOf="@id/sopra"
        app:layout_constraintBottom_toTopOf="@id/medio"
        android:gravity="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:text="3D Easy"
        android:textColor="@color/_____cancel_text" />

    <ImageView
        android:padding="50dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/medio"
        app:layout_constraintBottom_toTopOf="@id/sotto"
        app:layout_constraintLeft_toRightOf="@id/v1"
        app:layout_constraintRight_toLeftOf="@id/v2"
        android:src="@drawable/dig_usermanual_qr_self_generated" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toRightOf="@id/v2"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sopra"
        app:layout_constraintBottom_toTopOf="@id/medio"
        android:gravity="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:text="3D Pro"
        android:textColor="@color/_____cancel_text" />

    <ImageView
        android:padding="50dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/medio"
        app:layout_constraintBottom_toTopOf="@id/sotto"
        app:layout_constraintLeft_toRightOf="@id/v2"
        app:layout_constraintRight_toRightOf="parent"
        android:src="@drawable/qr3dpro"

        />

    <ImageView
        android:id="@+id/chiud"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/btn_clear" />

    <ImageView
        android:id="@+id/anydesk"
        android:layout_width="60dp"
        android:layout_height="0dp"
        android:padding="5dp"
        android:layout_marginLeft="10dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/sopra"
        android:src="@drawable/anydesk_img" />

    <ImageView
        android:id="@+id/quickSupport"
        android:layout_width="60dp"
        android:layout_height="0dp"
        android:layout_marginLeft="50dp"
        android:padding="5dp"
        app:layout_constraintLeft_toRightOf="@id/anydesk"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/sopra"
        android:src="@drawable/qs_img" />

    <TextView
        android:id="@+id/titolo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toRightOf="@id/anydesk"
        app:layout_constraintRight_toLeftOf="@id/chiud"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/sopra"
        android:textColor="@color/_____cancel_text"
        android:textStyle="bold"
        android:gravity="center"
        android:textSize="22sp"
        android:text="USER GUIDES"
        android:background="@color/transparent" />

    <TextView
        android:id="@+id/testo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sotto"
        app:layout_constraintBottom_toBottomOf="parent"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:gravity="center"
        android:textSize="24sp"
        android:text="APOLLO8PROS"
        android:background="@color/_____cancel_text" />

</androidx.constraintlayout.widget.ConstraintLayout>