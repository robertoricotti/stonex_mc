<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.1" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6625" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.2875" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline123"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/VX1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.2" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/VX2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.35" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline125"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.8" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline124"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />


    <TextView
        android:id="@+id/titolo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_vertical"
        android:text="@string/gps_calib"
        android:textAlignment="textStart"
        android:textColor="@color/dark_gray"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/h1"
        app:layout_constraintLeft_toRightOf="@id/gpsdebugg"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="RtlCompat" />

    <ImageView
        android:id="@+id/gpsdebugg"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toTopOf="@+id/h1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/titolo"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/gps_no" />

    <Button
        android:id="@+id/updateGps"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="@color/light_yellow"
        android:gravity="center"
        android:text="UPDATE"
        android:textAllCaps="true"
        android:textColor="@color/_____cancel_text"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="@id/guideline124"
        app:layout_constraintRight_toRightOf="@id/guideline124"
        app:layout_constraintTop_toTopOf="@+id/h5" />

    <Button
        android:id="@+id/save"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="@color/blue"
        android:gravity="center"
        android:text="@string/save"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline124"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/h5" />

    <Button
        android:id="@+id/exit"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="@color/dark_gray"
        android:gravity="center"
        android:text="@string/exit"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline124"
        app:layout_constraintTop_toTopOf="@+id/h5" />

    <TextView
        android:id="@+id/textView48"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ΔX (m)"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/deltaX"
        app:layout_constraintLeft_toLeftOf="@id/deltaX"
        app:layout_constraintRight_toRightOf="@id/deltaX" />

    <TextView
        android:id="@+id/textView49"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ΔY (m)"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/deltaY"
        app:layout_constraintEnd_toStartOf="@+id/guideline125"
        app:layout_constraintStart_toStartOf="@+id/guideline123"
         />

    <TextView
        android:id="@+id/textView52"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ΔZ (m)"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/deltaZ"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/VX1" />
    <TextView
        android:id="@+id/txtBleft"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Right Side(m)"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/bladeL"
        app:layout_constraintLeft_toLeftOf="@id/bladeL"
        app:layout_constraintRight_toRightOf="@id/bladeL"
        />
    <TextView
        android:id="@+id/txtBright"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Left Side(m)"
        android:gravity="right"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/bladeR"
        app:layout_constraintLeft_toLeftOf="@id/bladeR"
        app:layout_constraintRight_toRightOf="@id/bladeR"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:text=" BLADE FRONT VIEW "
        android:gravity="right"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/txtBright"
        app:layout_constraintLeft_toRightOf="@id/txtBleft"
        app:layout_constraintRight_toLeftOf="@id/txtBright"
        />
    <TextView
        android:id="@+id/txtPole"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pole Height(m)"
        android:gravity="right"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/altPalo"
        app:layout_constraintLeft_toLeftOf="@id/altPalo"
        app:layout_constraintRight_toRightOf="@id/altPalo"
        />
    <TextView
        android:id="@+id/txLama"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Blade Height(m)"
        android:gravity="right"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/alteLama"
        app:layout_constraintLeft_toLeftOf="@id/alteLama"
        app:layout_constraintRight_toRightOf="@id/alteLama"
        />
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ΔHDT (°)"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/deltaHDT"
        app:layout_constraintEnd_toStartOf="@+id/guideline125"
        app:layout_constraintStart_toStartOf="@+id/guideline123"
        />

    <EditText
        android:id="@+id/deltaX"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/h2"
        app:layout_constraintLeft_toRightOf="@id/VX1"
        app:layout_constraintRight_toLeftOf="@id/VX2"
        app:layout_constraintTop_toTopOf="@+id/h1" />

    <EditText
        android:id="@+id/deltaY"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/h2"
        app:layout_constraintLeft_toRightOf="@id/guideline123"
        app:layout_constraintRight_toLeftOf="@id/guideline125"
        app:layout_constraintTop_toTopOf="@+id/h1" />


    <EditText
        android:id="@+id/deltaHDT"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintRight_toLeftOf="@id/guideline125"
        app:layout_constraintLeft_toRightOf="@id/guideline123"
        app:layout_constraintBottom_toTopOf="@+id/h5"
        app:layout_constraintTop_toTopOf="@+id/h4" />

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/doza_blade_altezza"
        app:layout_constraintBottom_toTopOf="@id/h5"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="@id/guideline124"
        app:layout_constraintTop_toBottomOf="@id/h1"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/doza_blade_y_2"
        app:layout_constraintBottom_toTopOf="@id/h5"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintLeft_toRightOf="@id/guideline124"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/h1"
        app:layout_constraintVertical_bias="1.0" />

    <EditText
        android:id="@+id/deltaZ"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/h3"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/VX1"
        app:layout_constraintTop_toTopOf="@+id/h3" />

    <EditText
        android:id="@+id/bladeL"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"

        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/h5"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/bladeR"
        app:layout_constraintTop_toTopOf="@+id/h4" />

    <EditText
        android:id="@+id/bladeR"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/h5"
        app:layout_constraintLeft_toRightOf="@id/bladeL"
        app:layout_constraintRight_toLeftOf="@id/guideline124"
        app:layout_constraintTop_toTopOf="@+id/h4" />

    <EditText
        android:id="@+id/alteLama"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="20dp"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/h4"
        app:layout_constraintLeft_toLeftOf="@id/bladeR"
        app:layout_constraintRight_toRightOf="@id/guideline124" />

    <EditText
        android:id="@+id/altPalo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/h3"
        app:layout_constraintLeft_toLeftOf="@id/bladeR"
        app:layout_constraintRight_toRightOf="@id/guideline124"
        app:layout_constraintTop_toTopOf="@id/h2" />
    <TextView
        android:id="@+id/textViewDistBetween"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Right Edge >> GPS2 (m)"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/distBetween"
        app:layout_constraintLeft_toLeftOf="@id/distBetween"
        app:layout_constraintRight_toRightOf="@id/distBetween"
        />

    <EditText
        android:id="@+id/distBetween"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:background="@color/white"
        android:backgroundTint="#BBFFFFFF"
        android:digits="0123456789."
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:imeOptions="flagNoExtractUi|actionDone"
        android:inputType="numberSigned"
        android:maxLines="1"
        android:paddingHorizontal="30dp"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/h3"
        app:layout_constraintLeft_toLeftOf="@id/bladeL"
        app:layout_constraintRight_toRightOf="@id/bladeL"
        app:layout_constraintTop_toTopOf="@id/h2" />
</androidx.constraintlayout.widget.ConstraintLayout>