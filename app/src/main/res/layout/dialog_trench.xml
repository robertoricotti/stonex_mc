<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nav_gray_color"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/titolo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:gravity="center"
        android:text="TRENCH SECTION VIEW"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"


        />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/v_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.65" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h_0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.88" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/vistaTrench"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titolo"
        app:layout_constraintBottom_toTopOf="@id/h_0"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/v_50">

        <gui.projects.SezioneTrenchView
            android:id="@+id/sezioneView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#EEEEEE"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/ok"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:text="@string/save"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:backgroundTint="@color/blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/reload"
        app:layout_constraintTop_toBottomOf="@id/h_0" />

    <Button
        android:id="@+id/reload"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:text="UPDATE"
        android:textColor="@color/_____cancel_text"
        android:textSize="20sp"
        android:backgroundTint="@color/yellow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/ok"
        app:layout_constraintRight_toLeftOf="@id/cancel"
        app:layout_constraintTop_toBottomOf="@id/h_0" />

    <Button
        android:id="@+id/cancel"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:text="@string/exit"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:backgroundTint="@color/_____cancel_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/reload"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/h_0" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintLeft_toRightOf="@id/v_50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/h_0"
        app:layout_constraintRight_toRightOf="parent"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center">

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/_____cancel_text"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:text="P Start Z"
                    android:layout_marginTop="20dp" />

                <EditText
                    android:id="@+id/et_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:focusableInTouchMode="false"
                    android:inputType="numberDecimal|numberSigned"
                    android:digits="0123456789.-"
                    android:maxLines="1"
                    android:gravity="center"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txEnd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/_____cancel_text"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:text="P End Z"
                    android:layout_marginTop="20dp" />

                <EditText
                    android:id="@+id/et_end"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:focusableInTouchMode="false"
                    android:inputType="numberDecimal|numberSigned"
                    android:digits="0123456789.-"
                    android:maxLines="1"
                    android:gravity="center"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tx1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:text="CL ELEVATION MODE"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/mantieni"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:src="@drawable/chart_96" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/_____cancel_text" />

            <ImageView
                android:id="@+id/spiana"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:src="@drawable/cogo_line_extend" />

        </LinearLayout>

        <TextView
            android:id="@+id/tx2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:text="LEFT WIDTH % SLOPE"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <EditText
                android:id="@+id/leftW"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="8"
                android:textSize="20sp"
                android:focusableInTouchMode="false"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:maxLines="1"
                android:gravity="center"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/_____cancel_text"
                android:layout_marginHorizontal="20dp" />

            <EditText
                android:id="@+id/leftS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="8"
                android:textSize="20sp"
                android:focusableInTouchMode="false"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:maxLines="1"
                android:gravity="center"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tx3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:text="RIGHT WIDTH % SLOPE"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <EditText
                android:id="@+id/rightW"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="8"
                android:textSize="20sp"
                android:focusableInTouchMode="false"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:maxLines="1"
                android:gravity="center"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/_____cancel_text"
                android:layout_marginHorizontal="20dp" />

            <EditText
                android:id="@+id/rightS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="8"
                android:textSize="20sp"
                android:focusableInTouchMode="false"
                android:inputType="numberDecimal|numberSigned"
                android:digits="0123456789.-"
                android:maxLines="1"
                android:gravity="center"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>