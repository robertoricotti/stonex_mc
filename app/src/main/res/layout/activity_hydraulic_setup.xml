<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="gui.debug_ecu.Hydraulic_Setup">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideMezzo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.44" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.88" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLowMid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.72" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.1" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.9" />

    <TextView
        android:id="@+id/txt_page"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/transparent"
        android:gravity="center"
        android:lines="2"
        android:text="1/10"
        android:textColor="@color/_____cancel_text"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/page_meno"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/guideMezzo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="@id/guideLeft"
        app:layout_constraintTop_toTopOf="@id/guideMezzo"

        />

    <ImageView
        android:id="@+id/page_piu"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/btn_fwd"
        app:layout_constraintBottom_toBottomOf="@id/guideMezzo"
        app:layout_constraintLeft_toRightOf="@id/guideRight"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideMezzo" />

    <ImageView
        android:id="@+id/image_function"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        android:scaleType="centerInside"
        android:src="@drawable/btn_ecu"
        app:layout_constraintBottom_toTopOf="@id/txt_funzione"
        app:layout_constraintLeft_toRightOf="@id/guideLeft"
        app:layout_constraintRight_toLeftOf="@id/guideRight"
        app:layout_constraintTop_toBottomOf="@id/txt_page" />

    <TextView
        android:id="@+id/txt_funzione"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="DESCRIPTION\nHERE\nMAYBE MORE THAN\nJUST ONE LINE"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/image_function"
        app:layout_constraintLeft_toRightOf="@id/guideLeft"
        app:layout_constraintRight_toLeftOf="@id/guideRight"
        app:layout_constraintTop_toBottomOf="@id/guideLowMid" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="18dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/guideLow"
        app:layout_constraintLeft_toRightOf="@id/guideLeft"
        app:layout_constraintRight_toLeftOf="@id/guideRight"
        app:layout_constraintTop_toBottomOf="@id/guideLowMid">

        <ImageButton
            android:id="@+id/btn_plu"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_transp_2"
            android:src="@drawable/btn_su" />

        <TextView
            android:id="@+id/testo"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:ems="8"
            android:gravity="center"
            android:text=""
            android:textSize="37sp"
            android:textStyle="bold" />


        <ImageButton
            android:id="@+id/btn_min"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/custom_background_transp_2"
            android:src="@drawable/btn_giu" />


    </LinearLayout>


    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:background="@color/nav_gray_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideLow">

        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/back_btn" />


        <ImageView
            android:id="@+id/ecustatus"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_weight="2.5"
            android:background="@color/nav_gray_color"
            android:padding="1dp"
            android:src="@drawable/ko_ecu_bosch" />

        <ImageButton
            android:id="@+id/btn_testH"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:layout_margin="2dp"
            android:backgroundTint="@color/bg_sfsred"
            android:scaleType="centerInside"
            android:src="@drawable/btn_ylinder"
            />
        <ImageButton
            android:id="@+id/set_all_defaults"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_weight="0.5"
            android:background="@color/nav_gray_color"
            android:padding="5dp"
            android:layout_margin="2dp"
            android:backgroundTint="@color/GROUNDbg_stonex_blue"
            android:scaleType="centerInside"
            android:src="@drawable/btn_set_all_defaults"
            android:visibility="gone"/>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>