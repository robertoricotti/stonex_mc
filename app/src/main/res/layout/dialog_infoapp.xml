<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/sfondo_dialog_chiara">
    <TextView
        android:id="@+id/testo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/chiudi"
        android:gravity="center"
        android:textColor="@color/_____cancel_text"
        android:textSize="18sp"
        android:textStyle="italic|bold"
        android:text="Testo Prova\nTesto Prova a capo"
        android:layout_marginVertical="10dp"
        />


    <ImageView
        android:id="@+id/chiudi"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/btn_close_web"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginVertical="15dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>