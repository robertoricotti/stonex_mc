<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="hydro.CAT_SEA_Activity"
    android:background="@color/bg_gray">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.09" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/botla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.89" />
    <TextView
        android:id="@+id/titolo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/topla"
        android:gravity="center"
        android:textStyle="bold|italic"
        android:textSize="36sp"
        android:text="CAT - SEA"
        android:background="@color/_____cancel_text"
        android:textColor="@color/white"
        />
    <TextView
        android:id="@+id/funzione"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="36sp"
        android:text="LEFT MINIMUM DOWN"
        android:textColor="@color/blue"
        app:layout_constraintTop_toBottomOf="@id/topla"
        app:layout_constraintBottom_toTopOf="@id/testo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <TextView
        android:id="@+id/testo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="26sp"
        android:text="a\nb\nc\nd\ne"
        android:layout_margin="5dp"
        app:layout_constraintTop_toBottomOf="@id/funzione"
        app:layout_constraintBottom_toTopOf="@id/valore"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <ImageView
        android:id="@+id/val_P"
    android:layout_width="0dp"
    android:layout_height="0dp"
        app:layout_constraintLeft_toRightOf="@id/valore"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/valore"
        app:layout_constraintBottom_toBottomOf="@id/valore"
        android:src="@drawable/btn_fwd"
        android:rotation="270"
        />
    <EditText
        android:id="@+id/valore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="38sp"
        android:layout_margin="5dp"
        android:padding="2dp"
        android:text="255"
        android:ems="10"
        android:focusableInTouchMode="false"
        android:digits="0123456789"
        android:textColor="@color/blue"
        android:background="@drawable/sfondo_bottone_bianco"
        app:layout_constraintTop_toBottomOf="@id/testo"
        app:layout_constraintBottom_toTopOf="@id/centa"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
    <ImageView
        android:id="@+id/val_M"
        android:layout_width="0dp"
        android:layout_height="0dp"
app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/valore"
        app:layout_constraintTop_toTopOf="@id/valore"
        app:layout_constraintBottom_toBottomOf="@id/valore"
        android:src="@drawable/btn_fwd"
        android:rotation="90"
        />
   <LinearLayout
       android:layout_width="match_parent"
       android:layout_height="0dp"
       app:layout_constraintTop_toBottomOf="@id/centa"
       app:layout_constraintBottom_toTopOf="@id/botla"
       android:orientation="horizontal"
       android:gravity="center">
       <ImageView
           android:id="@+id/toleft"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:src="@drawable/back_btn"
           android:layout_weight="1"
           />
       <TextView
           android:id="@+id/test"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:background="@drawable/sfondo_bottone_selezionato"
           android:text="  TEST  "
           android:textStyle="bold"
           android:textColor="@color/red"
           android:gravity="center"
           android:textSize="48sp"
           android:layout_weight="0.5"/>
       <ImageView
           android:id="@+id/toright"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:src="@drawable/back_btn"
           android:rotation="180"
           android:layout_weight="1"
          />
   </LinearLayout>

    <LinearLayout
        android:id="@+id/lowerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:background="@drawable/custom_background_test3d_box"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/botla">

        <ImageView
            android:id="@+id/btn_1"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="1.5dp"
            android:layout_marginTop="2dp"
            android:padding="5dp"
            android:scaleType="centerInside"
            app:tint="@color/white"
            android:rotation="180"
            app:srcCompat="@drawable/menu_btn" />


        <TextView

            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:layout_weight="1"
            android:gravity="center|right"
            android:textStyle="bold|italic"
            android:textSize="36sp"
            android:text="Machine Model:"
            android:background="@color/_____cancel_text"
            android:textColor="@color/white"/>
        <TextView
            android:id="@+id/txtTipo"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textStyle="bold|italic"
            android:textSize="36sp"
            android:text="CAT K-N"
            android:background="@color/_____cancel_text"
            android:textColor="@color/yellow"/>




    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>