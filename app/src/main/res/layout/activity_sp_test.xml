<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">



        <Button
            android:id="@+id/btnLoad"
            android:text="USE ACTUAL LOCALIZATION FILE"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            />

        <TextView
            android:text="→ Input Geo (Lat/Lon/H)"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/etLat"
            android:hint="Latitude (°)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberSigned|numberDecimal"
            android:imeOptions="actionDone"
            />

        <EditText
            android:id="@+id/etLon"
            android:hint="Longitude (°)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberSigned|numberDecimal"
            android:imeOptions="actionDone"/>

        <EditText
            android:id="@+id/etH"
            android:hint="Elevation (m)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberSigned|numberDecimal"
            android:imeOptions="actionDone"/>

        <Button
            android:id="@+id/btnTransform"
            android:text="→ Transform in Local (N, E ,Z)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:text="→ Input Local (E/N/Z)"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />



        <EditText
            android:id="@+id/etNord"
            android:hint="North (m)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:imeOptions="actionDone"/>
        <EditText
            android:id="@+id/etEst"
            android:hint="East (m)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:imeOptions="actionDone"/>

        <EditText
            android:id="@+id/etZ"
            android:hint="Elevation (m)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:imeOptions="actionDone"/>

        <Button
            android:id="@+id/btnInverse"
            android:text="← Transform in Geo (Lat,Lon,H)"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#111"
            android:padding="8dp"
            android:background="#f0f0f0"
            android:layout_marginTop="10dp" />
        <Space
            android:layout_width="wrap_content"
            android:layout_height="5dp"/>
        <Button
            android:id="@+id/btn_Exit"
            android:text="EXIT"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
