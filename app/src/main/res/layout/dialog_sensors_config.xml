<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_gray">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideCent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"
        android:orientation="vertical" />

    <ImageView
        android:id="@+id/leftSensor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="100dp"
        android:src="@drawable/bucket"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/clos"
        app:layout_constraintRight_toLeftOf="@id/guideCent" />

    <ImageView
        android:id="@+id/rightSensor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="100dp"
        android:src="@drawable/tsm_uno_rsized"
        app:layout_constraintLeft_toRightOf="@id/guideCent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/clos"
        app:layout_constraintRight_toRightOf="parent" />

    <View
        android:layout_width="5dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/clos"
        app:layout_constraintLeft_toRightOf="@id/guideCent"
        app:layout_constraintRight_toLeftOf="@id/guideCent"
        android:background="@color/_____cancel_text" />

    <Button
        android:id="@+id/save"
        android:layout_width="130dp"
        android:layout_height="70dp"
        android:text="OK"
        android:textColor="@color/white"
        android:backgroundTint="@color/blue"
        android:textSize="25sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/clos" />

    <Button
        android:id="@+id/clos"
        android:layout_width="130dp"
        android:layout_height="70dp"
        android:text="@string/exit"
        android:textColor="@color/white"
        android:backgroundTint="@color/dark_gray"
        android:textSize="25sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/save"
        app:layout_constraintRight_toRightOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>