<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sfondo_bottone_bianco">


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h66"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.45" />
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/h75"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.75" />

    <View
        android:id="@+id/img_0"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="15dp"
        android:padding="30dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toTopOf="@id/h66"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/img_1"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@color/black"/>
    <ImageView
        android:visibility="gone"
        android:id="@+id/sel0"
        android:src="@drawable/baseline_check_96"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/h66"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/img_1"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/green" />

    <View
        android:id="@+id/img_1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="15dp"
        android:background="@color/light_gray"
        android:paddingVertical="70dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toTopOf="@id/h66"
        app:layout_constraintLeft_toRightOf="@id/img_0"
        app:layout_constraintRight_toLeftOf="@id/img_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:visibility="gone"
        android:id="@+id/sel1"
        android:src="@drawable/baseline_check_96"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toLeftOf="@id/img_2"
        app:layout_constraintBottom_toTopOf="@id/h66"
        app:layout_constraintLeft_toRightOf="@id/img_0"
        app:layout_constraintTop_toTopOf="parent"
         app:tint="@color/green" />

    <View
        android:id="@+id/img_2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="15dp"
        android:padding="30dp"
        android:scaleType="fitXY"
        android:background="@drawable/custom_background_transp_2"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toTopOf="@id/h66"
        app:layout_constraintLeft_toRightOf="@id/img_1"
        app:layout_constraintTop_toTopOf="parent"

        />
    <ImageView
        android:id="@+id/sel2"
        android:visibility="gone"
        android:src="@drawable/baseline_check_96"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toTopOf="@id/h66"
        app:layout_constraintLeft_toRightOf="@id/img_1"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/green" />

    <ImageView
        android:id="@+id/save"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:backgroundTint="@color/blue"

        android:src="@drawable/save_btn"
        android:layout_marginVertical="40dp"
        app:layout_constraintTop_toBottomOf="@id/luminosita"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/exit"
        app:layout_constraintStart_toStartOf="parent"
         />


    <ImageView
        android:id="@+id/exit"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:backgroundTint="@color/dark_gray"
        android:text="@string/exit"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:src="@drawable/btn_close_web"
        app:layout_constraintTop_toBottomOf="@id/luminosita"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/save"
        />

    <TextView
        android:id="@+id/titoloF"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:gravity="center"
        android:text="BRIGHTNESS\n\n0%"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/luminosita"
        app:layout_constraintTop_toBottomOf="@id/h66"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>



    <SeekBar
        android:id="@+id/luminosita"
        style="@style/Widget.AppCompat.SeekBar.Discrete"

        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="10"
        android:progress="1"
        android:layout_marginVertical="50dp"
        app:layout_constraintTop_toBottomOf="@id/titoloF"

       app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />
</androidx.constraintlayout.widget.ConstraintLayout>